<UserControl x:Class="캠핑_정보_탐색_프로그램.Views.CompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F1E8">

    <UserControl.Resources>

        <Style x:Key="CompareLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F3525"/>
            <Setter Property="Margin" Value="16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompareValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F5F1E8">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="105"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <Border Grid.Row="0"
                Background="#E9F0E3"
                BorderBrush="#C8D6BF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20,0">

            <TextBlock Text="⚖ 캠핑장 비교"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1F3525"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- 안내 -->
        <Border Grid.Row="1"
                Background="#FAF9F3"
                BorderBrush="#AFC8A8"
                BorderThickness="2"
                CornerRadius="18"
                Margin="0,15,0,10"
                Padding="12">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="⚖"
                           FontSize="32"
                           HorizontalAlignment="Center"/>

                <TextBlock FontSize="20"
                           FontWeight="Bold"
                           Foreground="#1F3525"
                           HorizontalAlignment="Center">

                    <Run Text="비교할 캠핑장 "/>
                    <Run Text="{Binding CompareCamps.Count, Mode=OneWay}"/>
                    <Run Text="개를 선택했습니다."/>

                </TextBlock>

                <TextBlock Text="아래 항목을 비교하여 나에게 맞는 캠핑장을 선택해보세요!"
                           FontSize="13"
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 비교 내용 -->
        <Grid Grid.Row="2">

            <!-- 비교 목록 없을 때 -->
            <Border Background="#FAF9F3"
                    BorderBrush="#D8C7A8"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="40">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CompareCamps.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock Text="⚖"
                               FontSize="60"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="아직 비교할 캠핑장이 없습니다."
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F3525"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="검색 화면에서 📊 비교추가를 눌러보세요."
                               FontSize="15"
                               Foreground="#666"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 비교 목록 있을 때 -->
            <Grid>

                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CompareCamps.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 항목 -->
                <Border Grid.Column="0"
                        Background="#F7F5EC"
                        BorderBrush="#D8C7A8"
                        BorderThickness="1"
                        CornerRadius="16"
                        Margin="0,0,10,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="62"/>
                            <RowDefinition Height="55"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="비교 항목"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="#1F3525"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Text="🖼 이미지" Style="{StaticResource CompareLabelStyle}"/>
                        <TextBlock Grid.Row="2" Text="📍 주소" Style="{StaticResource CompareLabelStyle}"/>
                        <TextBlock Grid.Row="3" Text="📌 위치 / 거리" Style="{StaticResource CompareLabelStyle}"/>
                        <TextBlock Grid.Row="4" Text="⛺ 총 사이트 수" Style="{StaticResource CompareLabelStyle}"/>
                        <TextBlock Grid.Row="5" Text="🐾 반려동물" Style="{StaticResource CompareLabelStyle}"/>
                        <TextBlock Grid.Row="6" Text="🌐 바로가기" Style="{StaticResource CompareLabelStyle}"/>
                        <TextBlock Grid.Row="7" Text="🗑 삭제" Style="{StaticResource CompareLabelStyle}"/>
                    </Grid>
                </Border>

                <!-- 오른쪽 캠핑장 카드 -->
                <ItemsControl Grid.Column="1"
                              ItemsSource="{Binding CompareCamps}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="#FAF9F3"
                                    BorderBrush="#D8C7A8"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Margin="6,0,0,0">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="45"/>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="62"/>
                                        <RowDefinition Height="55"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Name}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1F3525"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Row="1"
                                            Margin="15,8"
                                            Background="#DDE5D3"
                                            CornerRadius="12"
                                            ClipToBounds="True">

                                        <Image Source="{Binding ImageUrl}"
                                               Stretch="UniformToFill"/>
                                    </Border>

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Address}"
                                               Style="{StaticResource CompareValueStyle}"/>

                                    <TextBlock Grid.Row="3"
                                               Text="{Binding DistanceText}"
                                               Style="{StaticResource CompareValueStyle}"/>

                                    <TextBlock Grid.Row="4"
                                               Style="{StaticResource CompareValueStyle}">
                                        <Run Text="{Binding TotalSiteCount}"/>
                                        <Run Text="개"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="5"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="#2D7D2D"
                                               Margin="16,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="불가능"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PetAllowed}" Value="True">
                                                        <Setter Property="Text" Value="가능"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Row="6"
                                               Text="{Binding Homepage}"
                                               FontSize="13"
                                               Foreground="#2D7D2D"
                                               TextDecorations="Underline"
                                               Margin="16,0"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>

                                    <Button Grid.Row="7"
                                            Height="35"
                                            Margin="16,8"
                                            Background="#E94B4B"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.RemoveCompareCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗑" Margin="0,0,5,0"/>
                                            <TextBlock Text="비교 삭제"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>

        <!-- 돌아가기 -->
        <Button Grid.Row="3"
                Width="300"
                Height="38"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                Background="#E9F0E3"
                BorderBrush="#C8D6BF"
                BorderThickness="1"
                FontSize="15"
                FontWeight="Bold"
                Foreground="#1F3525"
                Cursor="Hand"
                Command="{Binding MoveSearchCommand}">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="←" FontSize="18" Margin="0,0,8,0"/>
                <TextBlock Text="캠핑장 선택 화면으로 돌아가기"/>
            </StackPanel>
        </Button>

    </Grid>
</UserControl>