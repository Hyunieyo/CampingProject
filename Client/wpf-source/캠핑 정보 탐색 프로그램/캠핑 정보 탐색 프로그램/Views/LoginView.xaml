<UserControl x:Class="캠핑_정보_탐색_프로그램.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F1E8">
    <UserControl.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="#F5F1E8">
        <Border Width="470"
                Background="#E9F0E3"
                BorderBrush="#C8D6BF"
                BorderThickness="1"
                CornerRadius="26"
                Padding="38"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="4"
                                  Opacity="0.25"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🏕 SH Camping"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#3A5A40"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Welcome Back"
                           FontSize="14"
                           Foreground="#6B705C"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="로그인"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#1F3525"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>
                <!-- 아이디 입력 영역 -->
                <TextBlock Text="아이디"
                           FontWeight="Bold"
                           Foreground="#1F3525"
                           Margin="0,0,0,6"/>
                <Border Background="#FAF9F3"
                        BorderBrush="#BFC8B8"
                        BorderThickness="1"
                        CornerRadius="14"
                        Height="46"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="👤"
                                   FontSize="17"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="txtID"
                                 Grid.Column="1"
                                 Style="{StaticResource InputTextBoxStyle}"/>
                        <TextBlock Grid.Column="1"
                                   Text="아이디를 입력하세요"
                                   Foreground="#9A9A9A"
                                   FontSize="14"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtID}"
                                                     Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <!-- 비밀번호 입력 영역 -->
                <TextBlock Text="비밀번호"
                           FontWeight="Bold"
                           Foreground="#1F3525"
                           Margin="0,0,0,6"/>
                <Border Background="#FAF9F3"
                        BorderBrush="#BFC8B8"
                        BorderThickness="1"
                        CornerRadius="14"
                        Height="46"
                        Margin="0,0,0,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒"
                                   FontSize="17"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <PasswordBox  x:Name="txtPW"
                                      Grid.Column="1"
                                      Style="{StaticResource InputPasswordBoxStyle}"
                                      PasswordChanged="txtPW_PasswordChanged"/>
                        <TextBlock x:Name="txtPWPlaceholder"
                                   Grid.Column="1"
                                   Text="비밀번호를 입력하세요"
                                   Foreground="#9A9A9A"
                                   FontSize="14"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <!-- 로그인 버튼 -->
                <Button Height="48"
                        Background="#3A5A40"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        Command="{Binding LoginSuccessCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="border"
                                            Property="Background"
                                            Value="#588157"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="border"
                                            Property="Opacity"
                                            Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="🔐"
                                   Margin="0,0,7,0"/>
                        <TextBlock Text="로그인"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>