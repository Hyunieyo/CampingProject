<UserControl x:Class="캠핑_정보_탐색_프로그램.Views.FavoriteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F1E8">

    <Grid Background="#F5F1E8">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 제목 -->
        <Border Grid.Row="0"
                Background="#E9F0E3"
                BorderBrush="#C8D6BF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20,0">

            <TextBlock Text="💚 찜 목록"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F3525"
                       VerticalAlignment="Center"/>

        </Border>

        <!-- 내용 -->
        <Grid Grid.Row="1"
              Margin="0,15,0,0">

            <!-- 비어있을 때 -->
            <Border x:Name="EmptyBorder"
                    Background="#FAF9F3"
                    BorderBrush="#B7C8AE"
                    BorderThickness="2"
                    CornerRadius="22"
                    Padding="50">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility"
                                Value="Collapsed"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding FavoriteCamps.Count}"
                                         Value="0">

                                <Setter Property="Visibility"
                                        Value="Visible"/>

                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock Text="💔"
                               FontSize="70"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="아직 찜한 캠핑장이 없습니다."
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F3525"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="검색 화면에서 💚 찜하기를 눌러보세요."
                               FontSize="16"
                               Foreground="#666"
                               Margin="0,14,0,0"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <!-- 리스트 -->
            <ListView x:Name="FavoriteListView"
                      ItemsSource="{Binding FavoriteCamps}"
                      Background="Transparent"
                      BorderThickness="0">

                <ListView.Style>
                    <Style TargetType="ListView">

                        <Setter Property="Visibility"
                                Value="Visible"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding FavoriteCamps.Count}"
                                         Value="0">

                                <Setter Property="Visibility"
                                        Value="Collapsed"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>
                </ListView.Style>

                <ListView.ItemTemplate>

                    <DataTemplate>

                        <Border Background="#FAF9F3"
                                BorderBrush="#E2D8C7"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18"
                                Margin="0,0,0,18">

                            <Border.Effect>

                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Opacity="0.12"/>

                            </Border.Effect>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <!-- 이미지 -->
                                <Border Width="230"
                                        Height="150"
                                        CornerRadius="14"
                                        ClipToBounds="True"
                                        Background="#DDE5D3">

                                    <Image Source="{Binding ImageUrl}"
                                           Stretch="UniformToFill"/>

                                </Border>

                                <!-- 정보 -->
                                <StackPanel Grid.Column="1"
                                            Margin="20,0,0,0"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               Foreground="#1F3525"/>

                                    <TextBlock Text="{Binding Address}"
                                               FontSize="18"
                                               Foreground="#666"
                                               Margin="0,14,0,0"/>

                                    <TextBlock Text="{Binding Tel}"
                                               FontSize="17"
                                               Foreground="#666"
                                               Margin="0,10,0,0"/>

                                    <TextBlock Text="{Binding FacilityInfo}"
                                               FontSize="16"
                                               Foreground="#666"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"/>

                                </StackPanel>

                                <!-- 버튼 -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">

                                    <!-- 상세보기 -->
                                    <Button Height="44"
                                            Margin="0,0,0,12"
                                            Background="#6EA36A"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            FontSize="15"
                                            Cursor="Hand">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">

                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="12">

                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>

                                                </Border>

                                            </ControlTemplate>
                                        </Button.Template>

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock Text="📄"
                                                       Margin="0,0,5,0"/>

                                            <TextBlock Text="상세보기"/>

                                        </StackPanel>

                                    </Button>

                                    <!-- 삭제 -->
                                    <Button Height="44"
                                            Background="#E85D5D"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            FontSize="15"
                                            Cursor="Hand">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">

                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="12">

                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>

                                                </Border>

                                            </ControlTemplate>
                                        </Button.Template>

                                        <StackPanel Orientation="Horizontal">

                                            <TextBlock Text="🗑"
                                                       Margin="0,0,5,0"/>

                                            <TextBlock Text="삭제하기"/>

                                        </StackPanel>

                                    </Button>

                                </StackPanel>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ListView.ItemTemplate>

            </ListView>
        </Grid>
    </Grid>
</UserControl>