<UserControl x:Class="캠핑_정보_탐색_프로그램.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F1E8">
    <UserControl.Resources>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#588157"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#F5F1E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="170"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 검색 영역 -->
        <Border Grid.Row="0"
                Background="#E9F0E3"
                BorderBrush="#C8D6BF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,0,10">
            <StackPanel>
                <!-- 기본 검색 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="캠핑장 검색"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1F3525"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBox Width="360"
                             Height="34"
                             Background="#FAF9F3"
                             BorderBrush="#BFC8B8"
                             VerticalContentAlignment="Center"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Width="100"
                            Height="34"
                            Margin="10,0,0,0"
                            Background="#3A5A40"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Command="{Binding SearchCommand}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="🔍"
                                       Margin="0,0,5,0"/>
                            <TextBlock Text="검색"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <!-- 상세 검색 -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,20,0,0">
                    <TextBlock Text="상세 검색"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#1F3525"
                               VerticalAlignment="Bottom"
                               Margin="0,0,18,6"/>
                    <!-- 도/시 -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="[도/시 검색]"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#3A5A40"
                                   Margin="0,0,0,4"/>
                        <ComboBox Width="130"
                                  Height="30"
                                  Background="#FAF9F3"/>
                    </StackPanel>
                    <!-- 시/군/구 -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="[시/군/구 검색]"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#3A5A40"
                                   Margin="0,0,0,4"/>
                        <ComboBox Width="130"
                                  Height="30"
                                  Background="#FAF9F3"/>
                    </StackPanel>
                    <!-- 캠핑 유형 -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="[캠핑 유형]"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#3A5A40"
                                   Margin="0,0,0,4"/>
                        <ComboBox Width="150"
                                  Height="30"
                                  Background="#FAF9F3"/>
                    </StackPanel>
                    <!-- 적용 버튼 -->
                    <Button Content="적용하기"
                            Width="95"
                            Height="30"
                            Margin="0,21,0,0"
                            Background="#A3B18A"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <!-- 검색 결과 -->
        <Border Grid.Row="1"
                Background="#F1E6D2"
                BorderBrush="#D8C7A8"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,0">
            <TextBlock FontSize="16"
                       FontWeight="Bold"
                       Foreground="#1F3525"
                       VerticalAlignment="Center">
                <Run Text="총 "/>
                <Run Text="{Binding Camps.Count, Mode=OneWay}"/>
                <Run Text="개의 캠핑장이 검색되었습니다."/>
            </TextBlock>
        </Border>
        <!-- 캠핑장 목록 -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding Camps}"
                  Background="Transparent"
                  BorderThickness="0"
                  Margin="0,10,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#FAF9F3"
                            BorderBrush="#D8C7A8"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="15"
                            Margin="0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="125"/>
                            </Grid.ColumnDefinitions>
                            <!-- 대표 이미지 -->
                            <Border Width="160"
                                    Height="110"
                                    Background="#DDE5D3"
                                    CornerRadius="12"
                                    ClipToBounds="True">
                                <Image Source="{Binding ImageUrl}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <!-- 캠핑장 정보 -->
                            <StackPanel Grid.Column="1"
                                        Margin="18,0,10,0">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="21"
                                           FontWeight="Bold"
                                           Foreground="#1F3525"/>
                                <TextBlock Text="{Binding Address}"
                                           FontSize="14"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Tel}"
                                           FontSize="14"
                                           Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding FacilityInfo}"
                                           FontSize="13"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <!-- 버튼 -->
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <Button Content="🏕 상세보기"
                                        Style="{StaticResource CardButtonStyle}"
                                        Command="{Binding DataContext.DetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="❤️ 찜하기"
                                        Background="#D97B66"
                                        Style="{StaticResource CardButtonStyle}"
                                        Command="{Binding DataContext.FavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="📊 비교추가"
                                        Background="#4F6D7A"
                                        Style="{StaticResource CardButtonStyle}"
                                        Command="{Binding DataContext.AddCompareCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>